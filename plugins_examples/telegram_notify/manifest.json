{
  "id": "com.linplayer.telegram-notify",
  "version": "1.0.0",
  "name": "Telegram 播放通知",
  "author": "LinPlayer",
  "description": "每播放完一集，自动通过 Telegram Bot 发送通知。可在设置中填写 Bot Token 和 Chat ID。",
  "main": "main.js",
  "homepage": "https://github.com/linplayer/plugins",
  "permissions": ["player.read", "http", "storage", "ui", "extensions"],
  "httpAllowedHosts": ["api.telegram.org"],
  "extends": {
    "settingsPages": [
      {
        "id": "settings",
        "title": "Telegram 通知设置",
        "handler": "openSettings"
      }
    ]
  }
}
