<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".ItemDetailActivity">

    <ImageView
        android:id="@+id/detail_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/detail_backdrop_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Main -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/detail_poster"
                    android:layout_width="180dp"
                    android:layout_height="270dp"
                    android:background="#26FFFFFF"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Title"
                        android:textSize="28sp" />

                    <TextView
                        android:id="@+id/detail_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:alpha="0.85"
                        android:text="Meta"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/detail_overview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Overview"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/detail_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_play"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/tv_focusable_bg"
                            android:minHeight="52dp"
                            android:text="@string/play" />

                        <Button
                            android:id="@+id/btn_favorite"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/tv_focusable_bg"
                            android:minHeight="52dp"
                            android:text="@string/favorite" />

                        <Button
                            android:id="@+id/btn_played"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/tv_focusable_bg"
                            android:minHeight="52dp"
                            android:text="@string/mark_played" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Seasons -->
            <LinearLayout
                android:id="@+id/season_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/season_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/season_select"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/season_input"
                        android:layout_width="110dp"
                        android:layout_height="44dp"
                        android:background="@drawable/tv_focusable_bg"
                        android:hint="@string/season_input_hint"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:singleLine="true" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/season_list"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <!-- Episodes -->
            <LinearLayout
                android:id="@+id/episode_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/episode_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/episode_select"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/episode_input"
                        android:layout_width="110dp"
                        android:layout_height="44dp"
                        android:background="@drawable/tv_focusable_bg"
                        android:hint="@string/episode_input_hint"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:singleLine="true" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/episode_list"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>

